# Ensure index.php is the default directory index
DirectoryIndex index.php index.html

RewriteEngine on

# Redirect HTTP to HTTPS
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Redirect direct .php requests to extensionless URLs
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^\ ]+)\.php
RewriteRule ^/?(.*)\.php$ /$1 [L,R=301]

# Remove .php extension from URLs internally
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

# Old URL redirects (301 Permanent Redirects)
RewriteRule ^about\.php$ /about [L,R=301]
RewriteRule ^about/$ /about [L,R=301]
RewriteRule ^appointment\.html$ /contact [L,R=301]
RewriteRule ^back-pain-treatment-in-india\.php$ /back-pain-treatment [L,R=301]
